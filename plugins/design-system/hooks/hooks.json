{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Read|WebFetch|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ds-hooks.sh"
          }
        ]
      },
      {
        "matcher": "mcp__figma-mcp-server__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ds-hooks.sh"
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Notion__notion-fetch|mcp__claude_ai_Notion__notion-search|mcp__claude_ai_Notion__notion-get-comments|mcp__claude_ai_Notion__notion-get-users|mcp__claude_ai_Notion__notion-get-teams",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ds-hooks.sh"
          }
        ]
      }
    ]
  }
}
